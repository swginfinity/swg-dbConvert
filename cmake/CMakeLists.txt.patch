# ============================================================================
# CMakeLists.txt additions for dbconvert
# ============================================================================
#
# Add these blocks to your existing src/CMakeLists.txt.
# Each section shows WHERE to add it relative to existing code.
#
# This is not a unified diff — it's a reference showing the exact lines to add.
# Lines starting with # EXISTING: are already in your file (for context).
# Lines starting with # ADD: are new lines you need to insert.
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# SECTION 1: Add executable (after the core3 executable definition)
# ──────────────────────────────────────────────────────────────────────────────

# EXISTING: add_executable(core3 main.cpp server/ServerCore.cpp ${core3tests_libs} ${tre3_sources} ${tre3_headers} ${zone3_sources} ${zone3_headers})
#
# ADD the following immediately after:

if(EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/tools/dbconvert.cpp")
add_executable(dbconvert EXCLUDE_FROM_ALL tools/dbconvert.cpp server/ServerCore.cpp ${tre3_sources} ${tre3_headers} ${zone3_sources} ${zone3_headers})
endif()

# ──────────────────────────────────────────────────────────────────────────────
# SECTION 2: Add dependencies (after core3 dependencies)
# ──────────────────────────────────────────────────────────────────────────────

# EXISTING: add_dependencies(core3 engine3)
#
# ADD the following immediately after:

if(TARGET dbconvert)
add_dependencies(dbconvert engine3 idlobjects)
endif()

# ──────────────────────────────────────────────────────────────────────────────
# SECTION 3: Add link libraries (after core3's link libs + jemalloc + gold)
# ──────────────────────────────────────────────────────────────────────────────

# EXISTING: if(ENABLE_MULTITHREADED_LINKER)
# EXISTING:     use_gold(core3)
# EXISTING: endif(ENABLE_MULTITHREADED_LINKER)
#
# ADD the following block after core3's gold linker conditional:

# dbconvert link libraries (same as core3)
if(TARGET dbconvert)
target_link_libraries(dbconvert
    ${whole_archive_start}
    db3 conf3 web3 status3 ping3 login3 chat3 core3terrain core3templates core3pathfinding idlobjects
    ${whole_archive_end}
    engine3
    ${Boost_LIBRARIES}
    ${GCCLIBATOMIC_LIBRARY} ${PTHREAD_LIB_LINK} ${MYSQL_LIB}
    ${LUA_LIBRARIES}
    ${DB_LIBRARIES} ${OPENSSL_LIBRARIES}
    ${ZLIB_LIBRARIES} ${CMAKE_DL_LIBS})

if (NOT ENABLE_ASAN AND NOT ENABLE_TSAN AND NOT ENABLE_UBSAN AND JEMALLOC_FOUND AND ENABLE_JEMALLOC_LINK)
    target_link_libraries(dbconvert ${JEMALLOC_LIBRARIES})
endif()

if(ENABLE_MULTITHREADED_LINKER)
    use_gold(dbconvert)
endif(ENABLE_MULTITHREADED_LINKER)

# Copy dbconvert binary to bin/
add_custom_command(
    TARGET dbconvert POST_BUILD
    COMMAND ${CMAKE_COMMAND} -E copy
    $<TARGET_FILE:dbconvert>
    ${CMAKE_SOURCE_DIR}/bin/)
endif()
